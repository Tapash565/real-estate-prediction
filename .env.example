# Real Estate Prediction API - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Data Configuration
# =============================================================================
REAL_ESTATE_DATA_PATH=data/raw/realtor-data.csv
REAL_ESTATE_TARGET_COLUMN=price

# =============================================================================
# Model Configuration
# =============================================================================
REAL_ESTATE_MODEL_TYPE=random_forest
# Options: linear, sgd, decision_tree, random_forest, gradient_boosting
REAL_ESTATE_N_SPLITS=5
REAL_ESTATE_RANDOM_STATE=42

# =============================================================================
# Paths
# =============================================================================
REAL_ESTATE_MODEL_PATH=models/latest_model.joblib
REAL_ESTATE_PIPELINE_PATH=models/preprocessing_pipeline.joblib
REAL_ESTATE_PROCESSED_DATA_PATH=data/processed/processed_data.csv
REAL_ESTATE_FIGURES_DIR=reports/figures

# =============================================================================
# API Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Application settings
APP_NAME="Real Estate Price Prediction API"
APP_VERSION=1.0.0
ENVIRONMENT=development

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json
# Options: json, console

# =============================================================================
# Security Configuration
# =============================================================================
# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
CORS_ORIGINS=*
CORS_CREDENTIALS=true

# =============================================================================
# Database / Cache Configuration
# =============================================================================
# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false

# Redis URL (alternative format)
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# ML Configuration
# =============================================================================
# MLflow Configuration
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=real-estate-prediction
MLFLOW_ARTIFACT_ROOT=./mlartifacts

# Retraining Configuration
RETRAINING_MAE_THRESHOLD=50000
RETRAINING_MIN_DAYS=1

# Drift Detection
DRIFT_THRESHOLD=0.05

# =============================================================================
# Monitoring Configuration
# =============================================================================
# Sentry Configuration (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=real-estate-api
OTEL_SERVICE_VERSION=1.0.0

# Monitoring Database
MONITORING_DB_PATH=./monitoring

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
# Rate limit storage (redis or memory)
RATELIMIT_STORAGE_URL=memory://
# For production use:
# RATELIMIT_STORAGE_URL=redis://localhost:6379

# =============================================================================
# A/B Testing Configuration
# =============================================================================
AB_TEST_ENABLED=true

# =============================================================================
# Feature Flags
# =============================================================================
FEATURE_CACHE_PREDICTIONS=true
FEATURE_MLFLOW_TRACKING=true
FEATURE_DRIFT_DETECTION=true
FEATURE_AUTO_RETRAINING=false

# =============================================================================
# Test Configuration
# =============================================================================
# Test database
TEST_DATABASE_URL=sqlite:///./test.db

# =============================================================================
# Docker Configuration
# =============================================================================
# Docker registry
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE=real-estate-prediction

# =============================================================================
# Production Settings
# =============================================================================
DEBUG=false
